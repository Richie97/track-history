{
  "name": "track-evolution-mobile",
  "private": true,
  "description": "Capacitor iOS/Android shell around the web app in ../public (synced by scripts/sync-www.mjs — never edit www/ by hand)",
  "scripts": {
    "sync": "node scripts/sync-www.mjs && cap sync",
    "ios": "npm run sync && cap open ios",
    "android": "npm run sync && cap open android",
    "assets": "npx @capacitor/assets generate"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.0",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/clipboard": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@capacitor/share": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  }
}
