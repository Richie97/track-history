<?xml version="1.0" encoding="utf-8"?>
<!-- Debug builds only: allow plain-http to a local dev server (the emulator
     reaches the host's `npm run dev` at http://10.0.2.2:8787). Release builds
     use the main manifest and stay https-only. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:usesCleartextTraffic="true" />
</manifest>
